# Azure OpenAI Configuration (uses az login credentials via DefaultAzureCredential)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_DEPLOYMENT_NAME=gpt-4o

# Code Graph
GRAPH_PATH=output/code-graph.json
INDEX_DB=output/file-index.db
REPO_ROOT=/path/to/kubernetes

# Documentation
DOCS_ROOT=/path/to/website/content/en/docs
DOCS_INDEX_DB=output/doc-index.db

# GitHub links
GITHUB_REPO_URL=https://github.com/kubernetes/kubernetes
GITHUB_BRANCH=master
DOCS_BASE_URL=https://kubernetes.io

# API Settings
MAX_CONTEXT_ITEMS=10
MAX_TOKENS=4000

# Auth (leave blank to disable auth)
AUTH_USERNAME=
AUTH_PASSWORD=

# CORS (comma-separated allowed origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
